library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity tb_two_bit_adder is
-- Testbench entity is empty
end tb_two_bit_adder;

architecture sim of tb_two_bit_adder is

    -- 1. Component Declaration for your exact entity
    component two_bit_adder is
        port (
            a    : in  std_logic_vector (1 downto 0);
            b    : in  std_logic_vector (1 downto 0);
            cin  : in  std_logic;
            sum  : out std_logic_vector (1 downto 0);
            cout : out std_logic
        );
    end component;

    -- 2. Testbench Signals
    signal a_tb    : std_logic_vector(1 downto 0) := "00";
    signal b_tb    : std_logic_vector(1 downto 0) := "00";
    signal cin_tb  : std_logic := '0';
    signal sum_tb  : std_logic_vector(1 downto 0);
    signal cout_tb : std_logic;

begin

    -- 3. Instantiate your UUT (Unit Under Test)
    uut: two_bit_adder port map (
        a    => a_tb,
        b    => b_tb,
        cin  => cin_tb,
        sum  => sum_tb,
        cout => cout_tb
    );

    -- 4. Stimulus and Self-Checking Process
    stim_proc: process
        variable expected_val : integer;
        variable actual_val   : integer;
        variable cin_int      : integer;
    begin
        wait for 10 ns;

        -- Loop to test both cin = '0' and cin = '1'
        for c in 0 to 1 loop
            if c = 0 then
                cin_tb <= '0';
                cin_int := 0;
            else
                cin_tb <= '1';
                cin_int := 1;
            end if;

            -- Exhaustive test loops for inputs A and B
            for i in 0 to 3 loop
                for j in 0 to 3 loop
                    
                    -- Assign stimulus
                    a_tb <= std_logic_vector(to_unsigned(i, 2));
                    b_tb <= std_logic_vector(to_unsigned(j, 2));
                    
                    -- Wait for structural logic to propagate
                    wait for 10 ns;

                    -- Calculate expected mathematical result
                    expected_val := i + j + cin_int;
                    
                    -- Calculate actual result from the UUT outputs
                    -- By concatenating cout and sum, we get a 3-bit result to convert to integer
                    actual_val := to_integer(unsigned(cout_tb & sum_tb));

                    -- 5. Self-Checking Assertion
                    -- If actual_val does not match expected_val, it stops and prints a failure message
                    assert (actual_val = expected_val)
                        report "TEST FAILED! a=" & integer'image(i) & 
                               " b=" & integer'image(j) & 
                               " cin=" & integer'image(cin_int) &
                               " | Expected: " & integer'image(expected_val) & 
                               ", Got: " & integer'image(actual_val)
                        severity failure;
                        
                end loop;
            end loop;
        end loop;

        -- If we reach this point, no assertions failed
        report "ALL TESTS PASSED SUCCESSFULLY!" severity note;
        
        -- End simulation
        wait;
    end process;

end sim;
